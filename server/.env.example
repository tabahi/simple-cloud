# simplecloud server configuration — copy to `server/.env` and edit.
# The real .env is gitignored, so your paths/certs/secrets stay off GitHub.
# Any variable already set in the environment overrides the value here.

# ── network ───────────────────────────────────────────────────────────────────
# Port Fastify listens on (nginx/proxy forwards to this). Not opened publicly.
SC_PORT=11277
# Bind address — localhost only; the reverse proxy handles external traffic.
SC_HOST=127.0.0.1

# ── storage paths ──────────────────────────────────────────────────────────────
# Live file blobs (flat, UUID filenames).
SC_STORAGE_DIR=/var/simplecloud/storage
# Pre-overwrite backups, grouped by date.
SC_TEMP_DIR=/var/simplecloud/temp
# Pino rolling log files (server.log) live here.
SC_LOG_DIR=/var/simplecloud/logs
# SQLite database directory (simplecloud.db).
SC_DB_DIR=/var/simplecloud
# Append-only JSON change log. Leave empty to default to <SC_LOG_DIR>/changes.log
SC_FILECHANGE_LOGS=

# ── process / backups ──────────────────────────────────────────────────────────
SC_PM2_NAME=simplecloud-server
# Delete backup date-dirs older than this many days.
SC_BACKUP_RETENTION_DAYS=7
# Files larger than this (bytes) are not backed up before overwrite.
SC_BACKUP_MAX_FILE_SIZE_BYTES=10485760

# ── secure locked folder ───────────────────────────────────────────────────────
# Path prefix of the secure folder (must match the client's SC_LOCKED_FOLDER_NAME).
SC_LOCKED_FOLDER_NAME=.simplecloud_locked
# Where the encrypted 7z archive is written when the folder is locked.
SC_LOCKED_ZIP=/var/simplecloud/locked.7z

# ── SSL / TLS ──────────────────────────────────────────────────────────────────
# Set true only if this server should terminate TLS directly (not via nginx).
SC_SSL_ENABLED=false
SC_SSL_CERT_FILE=/etc/letsencrypt/live/example.com/fullchain.pem
SC_SSL_KEY_FILE=/etc/letsencrypt/live/example.com/privkey.pem

# ── Discord bot (optional) ──────────────────────────────────────────────────────
SC_DISCORD_ENABLED=false
SC_DISCORD_TOKEN=
SC_DISCORD_CLIENT_ID=
SC_DISCORD_GUILD_ID=
# Comma-separated IDs. Empty + empty channels = bot denies everyone (fail-closed).
SC_DISCORD_ALLOWED_USER_IDS=
SC_DISCORD_ALLOWED_CHANNEL_IDS=
# Max attachment size to ingest/serve (default 25 MB — Discord's free cap).
SC_DISCORD_MAX_UPLOAD_BYTES=26214400

# ── Web UI (optional) ───────────────────────────────────────────────────────────
# A browser UI for full management. OFF by default. When enabled, login is a
# shared password PLUS a TOTP 2FA code (on by default), exchanged for an
# HttpOnly session cookie — the signing key is never exposed to the browser.
# Use `setup.sh` to enable it: it hashes your password and generates the TOTP
# secret + an otpauth:// URL to scan into an authenticator app.
SC_WEB_ENABLED=false
# scrypt hash of the web password, format "scrypt$<saltHex>$<hashHex>" (setup.sh writes this).
SC_WEB_PASSWORD_HASH=
# HMAC key used to sign session cookies (setup.sh auto-generates a random one).
SC_WEB_SESSION_SECRET=
# 2FA is ON by default. Set to false to allow password-only login (NOT recommended
# for a public deployment). If true, SC_WEB_TOTP_SECRET must be set or the web UI
# refuses to start (fail-closed).
SC_WEB_TOTP_ENABLED=true
# base32 TOTP secret (setup.sh auto-generates this and prints the otpauth:// URL).
SC_WEB_TOTP_SECRET=
# Session lifetime in minutes.
SC_WEB_SESSION_TTL_MINUTES=60


# ── compatibility ──────────────────────────────────────────────────────────────
# Clients older than this version will log an error and refuse to start.
SC_MIN_CLIENT_VERSION=1.0.0